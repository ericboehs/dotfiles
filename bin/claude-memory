<% else %>
  <ul class="space-y-2">
    <% @projects.each do |p| %>
      <li>
        <a href="/p/<%= h(p[:encoded]) %>" class="block rounded-lg border border-zinc-800 bg-zinc-900/40 hover:bg-zinc-900 hover:border-zinc-700 p-4 transition">
