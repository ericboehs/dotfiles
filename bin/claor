#!/usr/bin/env bash
set -euo pipefail

# Claude Code via OpenRouter (direct)

export ANTHROPIC_BASE_URL="https://openrouter.ai/api"
export ANTHROPIC_AUTH_TOKEN="${OPENROUTER_API_KEY:?Set OPENROUTER_API_KEY}"
export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

exec claude --mcp-config ~/.claude/mcp-brave.json "$@"
