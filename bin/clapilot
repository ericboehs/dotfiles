#!/usr/bin/env bash
set -euo pipefail

# Claude Code via GitHub Copilot Porxy
# https://github.com/ericc-ch/copilot-api

export ANTHROPIC_AUTH_TOKEN=dummy
export ANTHROPIC_BASE_URL=http://localhost:4141
export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
export ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8
export ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
export ANTHROPIC_MODEL=claude-opus-4-8
export ANTHROPIC_SMALL_FAST_MODEL=claude-haiku-4-5
export CLAUDE_AUTOCOMPACT_PCT_OVERRIDE=85
export CLAUDE_CODE_ATTRIBUTION_HEADER=0
export CLAUDE_CODE_AUTO_COMPACT_WINDOW=200000
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_MAX_OUTPUT_TOKENS=32000
export CLAUDE_CODE_SUBAGENT_MODEL=claude-opus-4-8
export DISABLE_NON_ESSENTIAL_MODEL_CALLS=1
# Disable claude.ai MCP connectors (inverted flag: 0/false/no/off = off). They
# can't work behind the dummy-token proxy anyway, and this silences the boot
# warning about ANTHROPIC_AUTH_TOKEN taking precedence over the claude.ai login.
export ENABLE_CLAUDEAI_MCP_SERVERS=0

exec claude \
  --mcp-config "$HOME/.claude/mcp-search.json" \
  --disallowed-tools WebSearch \
  --append-system-prompt "The built-in WebSearch tool is unavailable in this environment. For any web search, use the Tavily MCP tools instead." \
  "$@"
