#!/usr/bin/env python3
"""Extract markdown and comments from a .docx file.

Usage:
    docx-extract <file.docx>

Produces:
    <file>.md           - Document text as markdown (via pandoc)
    <file>.comments.md  - Comments with anchor text, grouped by author

Requires: pandoc
"""

import subprocess
import sys
import zipfile
import xml.etree.ElementTree as ET
from pathlib import Path
from collections import defaultdict
from shutil import which

W = "http://schemas.openxmlformats.org/wordprocessingml/2006/main"


def _tag(elem):
    """Strip namespace from element tag."""
    return elem.tag.split("}")[-1] if "}" in elem.tag else elem.tag


def _attr(elem, name):
    """Get a w: namespaced attribute."""
    return elem.get(f"{{{W}}}{name}", "")


# =============================================================================
# Document body -> Markdown (via pandoc)
# =============================================================================


def extract_markdown(docx_path: str, out_dir: Path) -> str:
    """Convert document body to markdown using pandoc."""
    media_dir = out_dir / "media"
    result = subprocess.run(
        [
            "pandoc", "-f", "docx", "-t", "markdown",
            "--wrap=none",
            f"--extract-media={out_dir}",
            str(docx_path),
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    return result.stdout


# =============================================================================
# Comments extraction
# =============================================================================


def extract_comments(docx_path: str) -> list[dict]:
    """Extract comments with their anchor text from the document body."""
    with zipfile.ZipFile(docx_path) as zf:
        names = zf.namelist()
        if "word/comments.xml" not in names:
            return []

        doc_tree = ET.parse(zf.open("word/document.xml"))
        com_tree = ET.parse(zf.open("word/comments.xml"))

    body = doc_tree.getroot().find(f".//{{{W}}}body")
    tokens = []

    def walk(elem):
        tag = _tag(elem)
        wid = _attr(elem, "id")
        if tag == "commentRangeStart":
            tokens.append(("START", wid))
        elif tag == "commentRangeEnd":
            tokens.append(("END", wid))
        elif tag == "t" and elem.text:
            tokens.append(("TEXT", elem.text))
        for child in elem:
            walk(child)

    walk(body)

    anchors: dict[str, list[str]] = {}
    active: set[str] = set()
    for ttype, val in tokens:
        if ttype == "START":
            active.add(val)
            anchors.setdefault(val, [])
        elif ttype == "END":
            active.discard(val)
        elif ttype == "TEXT":
            for cid in active:
                anchors[cid].append(val)

    comments = []
    for c in com_tree.getroot().findall(f".//{{{W}}}comment"):
        cid = _attr(c, "id")
        author = _attr(c, "author")
        date = _attr(c, "date")
        texts = [t.text for t in c.iter(f"{{{W}}}t") if t.text]
        body_text = "".join(texts).strip()
        if not body_text:
            continue

        anchor = "".join(anchors.get(cid, [])).strip()
        if len(anchor) > 200:
            anchor = anchor[:200] + "..."

        comments.append(
            {
                "id": cid,
                "author": author or "Unknown",
                "date": date[:10] if date else "",
                "text": body_text,
                "anchor": anchor or "(no anchor text)",
            }
        )

    return comments


def format_comments_md(comments: list[dict]) -> str:
    """Format comments as markdown, grouped by author."""
    by_author = defaultdict(list)
    for c in comments:
        by_author[c["author"]].append(c)

    lines = ["# Document Review Comments", ""]

    for author, author_comments in by_author.items():
        dates = sorted({c["date"] for c in author_comments if c["date"]})
        date_range = (
            f" ({dates[0]} to {dates[-1]})"
            if len(dates) > 1
            else f" ({dates[0]})"
            if dates
            else ""
        )
        lines.append(f"## {author}{date_range}")
        lines.append(f"*{len(author_comments)} comments*")
        lines.append("")

        for c in author_comments:
            lines.append("---")
            lines.append(f"### #{c['id']} — {c['date']}")
            lines.append(f'**On:** "{c["anchor"]}"')
            lines.append("")
            lines.append(f"> {c['text']}")
            lines.append("")

    return "\n".join(lines)


# =============================================================================
# CLI
# =============================================================================


def main():
    if len(sys.argv) < 2:
        print(__doc__.strip())
        sys.exit(1)

    docx_path = sys.argv[1]
    if not Path(docx_path).exists():
        print(f"Error: {docx_path} not found")
        sys.exit(1)

    if not which("pandoc"):
        print("Error: pandoc not found. Install with: brew install pandoc")
        sys.exit(1)

    stem = Path(docx_path).stem
    out_dir = Path(docx_path).parent

    # Extract markdown via pandoc
    md = extract_markdown(docx_path, out_dir)
    md_path = out_dir / f"{stem}.md"
    md_path.write_text(md)
    print(f"Markdown: {md_path} ({len(md.splitlines())} lines)")

    # Extract comments
    comments = extract_comments(docx_path)
    if comments:
        comments_md = format_comments_md(comments)
        comments_path = out_dir / f"{stem}.comments.md"
        comments_path.write_text(comments_md)
        print(f"Comments: {comments_path} ({len(comments)} comments)")
    else:
        print("No comments found in document.")


if __name__ == "__main__":
    main()
